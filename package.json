{
  "name": "ferencfarkas.org",
  "version": "1.7.202",
  "description": "The ferencfarkas.org project",
  "private": false,
  "scripts": {
    "start": "npm run website:serve",
    "dev": "run-p webapp:serve website:serve",
    "work:setdate": "node ./scripts/workdate",
    "prebuild": "node ./scripts/prebuild",
    "release": "node ./scripts/release",
    "release:check": "node ./scripts/release check",
    "scores": "node ./scripts/scores",
    "scores:diff": "node ./scripts/scores diff",
    "webapp:serve": "cd webapp && npm run dev",
    "webapp:build": "cd webapp && npm run build && cd ..",
    "website:serve": "npm run prebuild -- dev && cd ./website && hugo server --disableFastRender",
    "catalogue:pdf": "node ./catalogue/pdf-generator/index.js"
  },
  "dependencies": {
    "byte-size": "^9.0.1",
    "dotenv": "^17.3.1",
    "front-matter": "^4.0.2",
    "marked": "^17.0.3",
    "shelljs": "^0.10.0",
    "ssh2": "^1.17.0",
    "yaml": "^2.8.2"
  },
  "volta": {
    "node": "22.18.0"
  },
  "engines": {
    "node": ">= 22.0.0"
  },
  "devDependencies": {
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^25.3.5",
    "lunr": "^2.3.9",
    "lunr-languages": "^1.14.0",
    "npm-run-all": "^4.1.5",
    "run-p": "^0.0.0",
    "sirv-cli": "^3.0.1",
    "svelte": "^5.45.2",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
